# PostgreSQL connection string (Railway provides this)
DATABASE_URL="postgresql://user:password@localhost:5432/forecast_game?schema=public"

# JWT signing secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Server port
PORT=3001

# Comma-separated list of allowed frontend origins for CORS
# e.g. https://ekbugo.github.io  or  https://your-custom-domain.com
FRONTEND_ORIGIN="http://localhost:3000"

# Node environment
NODE_ENV="development"

# Path to the committed schedule.json (defaults to ../data-pull/schedule.json)
# SCHEDULE_PATH="../data-pull/schedule.json"

# Path to the puller output dir consumed by import-readings (defaults to ../data-pull/output)
# DATA_DIR="../data-pull/output"
